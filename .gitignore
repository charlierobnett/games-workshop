# Asset packs and zip originals — kept locally, never committed
# Pattern: ignore everything under shared/assets/ and shared/_originals/
# except the asset README that documents where packs come from.
shared/assets/**
!shared/assets/README.md
shared/_originals/

# Kenney Asset Launcher (if extracted anywhere inside the repo)
*Kenney Game Assets Launcher*/
*Kenney*Launcher*/

# Build provenance artifacts (per-game; useful locally, noisy in git)
games/*/.build-log.txt
games/*/.build-start.txt
games/*/.review-report.json